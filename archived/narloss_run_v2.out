Net(
  (op_embed): Linear(in_features=32, out_features=180, bias=True)
  (in_degree_embed): Linear(in_features=32, out_features=180, bias=True)
  (out_degree_embed): Linear(in_features=32, out_features=180, bias=True)
  (depth_embed): Linear(in_features=32, out_features=180, bias=True)
  (embed_proj): Linear(in_features=720, out_features=180, bias=True)
  (ml_encoder): MagLapEncoder(
    (f_elem): Sequential(
      (0): Linear(in_features=2, out_features=128, bias=True)
      (1): ReLU()
      (2): Linear(in_features=128, out_features=128, bias=True)
    )
    (norm): LayerNorm((128,), eps=1e-05, elementwise_affine=True)
    (attn): MultiheadAttention(
      (out_proj): NonDynamicallyQuantizableLinear(in_features=128, out_features=128, bias=False)
    )
    (drop): Dropout(p=0.15, inplace=False)
    (f_mix): Sequential(
      (0): Linear(in_features=640, out_features=128, bias=True)
      (1): ReLU()
      (2): Linear(in_features=128, out_features=180, bias=True)
    )
  )
  (encoder): TransformerEncoder(
    (layers): ModuleList(
      (0-9): 10 x GraphTransformerLayer(
        (norm1): LayerNorm((180,), eps=1e-05, elementwise_affine=True)
        (norm2): LayerNorm((180,), eps=1e-05, elementwise_affine=True)
        (self_attn): MultiHeadAttention(
          (qkv): Linear(in_features=180, out_features=540, bias=False)
          (proj): Linear(in_features=180, out_features=180, bias=False)
          (attn_dropout): Dropout(p=0.1, inplace=False)
          (resid_dropout): Dropout(p=0.1, inplace=False)
        )
        (ffn): BatchedMoEGraphFFN(
          (self_expert): Linear(in_features=180, out_features=720, bias=False)
          (in_expert): Linear(in_features=180, out_features=720, bias=False)
          (out_expert): Linear(in_features=180, out_features=720, bias=False)
          (gate): Sequential(
            (0): Linear(in_features=180, out_features=90, bias=False)
            (1): GELU(approximate='none')
            (2): Linear(in_features=90, out_features=3, bias=False)
          )
          (act): ReLU()
          (drop1): Dropout(p=0.1, inplace=False)
          (mix_norm): LayerNorm((720,), eps=1e-05, elementwise_affine=True)
          (fc2): Linear(in_features=720, out_features=180, bias=False)
          (drop2): Dropout(p=0.1, inplace=False)
        )
      )
    )
  )
  (post_norm): LayerNorm((180,), eps=1e-05, elementwise_affine=True)
  (att_pool): Linear(in_features=180, out_features=1, bias=True)
  (predictor): Linear(in_features=180, out_features=1, bias=True)
)
